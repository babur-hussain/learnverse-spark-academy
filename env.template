# 🔒 LEARNVERSE SECURITY ENVIRONMENT VARIABLES
# Copy this file to .env.local and update with your actual values

# ============================================================================
# API KEYS & SECRETS
# ============================================================================

# Google Gemini API Key (REQUIRED - Get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# JWT Secret for authentication (REQUIRED - Generate a secure random string)
JWT_SECRET=learnverse-super-secure-jwt-secret-2024-change-in-production

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# Allowed CORS origins (comma-separated list)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://localhost:3000,https://localhost:8080

# Environment (development, production, test)
NODE_ENV=development

# ============================================================================
# FIREBASE CONFIGURATION (Frontend)
# ============================================================================

# Firebase project config (from Firebase Console > Project Settings)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# ============================================================================
# EC2 BACKEND API
# ============================================================================

# API base URL (EC2 or localhost for development)
VITE_API_BASE_URL=http://localhost:5000

# ============================================================================
# AWS S3 CONFIGURATION (Backend — not exposed to frontend)
# ============================================================================

# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=ap-south-1
# S3_BUCKET_NAME=learnverse-uploads

# ============================================================================
# MONGODB CONFIGURATION (Backend — not exposed to frontend)
# ============================================================================

# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/learnverse

# ============================================================================
# PAYMENT INTEGRATION
# ============================================================================

# Razorpay Keys (if using payment features)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ============================================================================
# EMAIL & NOTIFICATIONS
# ============================================================================

# Email service configuration
EMAIL_SERVICE=sendgrid
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@yourdomain.com

# ============================================================================
# SECURITY FEATURES
# ============================================================================

# Enable virus scanning for file uploads
ENABLE_VIRUS_SCAN=false

# Security logging level
SECURITY_LOG_LEVEL=info

# Rate limiting configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# COMPLIANCE & PRIVACY
# ============================================================================

# GDPR compliance
GDPR_ENABLED=true
DATA_RETENTION_DAYS=365

# Data encryption
ENCRYPTION_ENABLED=true
ENCRYPTION_ALGORITHM=aes-256-gcm

# ============================================================================
# MONITORING & ANALYTICS
# ============================================================================

# Error tracking
SENTRY_DSN=your-sentry-dsn-here

# Performance monitoring
NEW_RELIC_LICENSE_KEY=your-new-relic-key-here

# ============================================================================
# DEVELOPMENT OVERRIDES
# ============================================================================

# Override security settings for development
DEV_MODE=true
SKIP_AUTH_VERIFICATION=false
SKIP_RATE_LIMITING=false

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================

# ⚠️  NEVER commit this file to version control
# ⚠️  NEVER share your API keys or secrets
# ⚠️  Use different keys for development and production
# ⚠️  Rotate keys regularly for production environments
# ⚠️  Monitor API usage and costs

# ============================================================================
# QUICK SETUP CHECKLIST
# ============================================================================

# ✅ GEMINI_API_KEY - Set to your actual Gemini API key
# ✅ JWT_SECRET - Generate a secure random string
# ✅ ALLOWED_ORIGINS - Update with your actual domains
# ✅ VITE_FIREBASE_API_KEY - Set from Firebase Console
# ✅ VITE_FIREBASE_PROJECT_ID - Set from Firebase Console
# ✅ VITE_API_BASE_URL - EC2 or localhost URL
# ✅ NODE_ENV - Set to 'production' for production deployment
