{
  "expo": {
    "name": "Padhaai Wala",
    "slug": "padhaaiwala",
    "description": "Padhaai Wala is a comprehensive learning platform.",
    "version": "1.6.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "padhaaiwala",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "privacy": "https://learnverse.lfvs.in/legal/privacy",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.padhaaiwala.app",
      "buildNumber": "10",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Padhaai Wala to access your camera to attach photos.",
        "NSMicrophoneUsageDescription": "Allow Padhaai Wala to access your microphone to record audio questions.",
        "NSPhotoLibraryUsageDescription": "Allow Padhaai Wala to access your photo library to attach images."
      }
    },
    "android": {
      "versionCode": 10,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "usesCleartextTraffic": false,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "predictiveBackGestureEnabled": false,
      "package": "com.padhaaiwala.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF6B35",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF8F0",
          "dark": {
            "backgroundColor": "#1A1A2E"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
