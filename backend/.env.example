# LearnVerse Backend Environment Variables

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/learnverse

# Firebase Admin (provide path to service account JSON OR the JSON string)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=learnverse-uploads

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Gemini AI (for AI Chat / Grading)
GEMINI_API_KEY=your-gemini-api-key
